# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/usedfarmmach?schema=public"

# JWT
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# Aliyun OSS
OSS_REGION="oss-cn-hangzhou"
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""
OSS_BUCKET="usedfarmmach"
OSS_ENDPOINT="https://oss-cn-hangzhou.aliyuncs.com"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_OSS_CDN=""

# AI Valuation API Keys
# 优先使用 Google Gemini API（免费）
# 获取地址：https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=""

# OpenRouter API（付费降级方案）
# 获取地址：https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=""

# ───────────────────────────────────────────────
# 微信客服（企微客服）回调 + AI 自动答 + 监控群推送
# 配置位置：企业微信管理后台 → 微信客服 → 你的客服账号 → 开发配置（接收消息）
# ───────────────────────────────────────────────
# 企业 ID（我的企业 → 企业信息 → 企业 ID）
WECOM_CORP_ID=""
# 接收消息配置里「Token」（你自己填的短串）
WECOM_KF_TOKEN=""
# 接收消息配置里「编码AES密钥」（点随机生成的 43 位）
WECOM_KF_AES_KEY=""
# 客服账号详情页「查看 Secret」后获取（发到企业微信客户端的那串）
WECOM_KF_SECRET=""
# 企微群 → 群机器人 → 复制的 Webhook 地址（可选，未配则跳过群推送）
WECOM_GROUP_WEBHOOK_URL=""
