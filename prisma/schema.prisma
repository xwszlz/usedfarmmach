generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String?    @unique
  username          String?    @unique
  phone             String?
  wxOpenid          String?
  passwordHash       String
  role              String    @default("buyer") // buyer, seller, admin, super_admin
  companyName       String?
  country           String?
  preferredLanguage String    @default("zh")
  credits           Int       @default(0)
  membershipTier    String    @default("free") // free, basic, premium, enterprise
  membershipExpiresAt DateTime?
  freeValuationsUsed   Int   @default(0)
  freeValuationsResetAt DateTime @default(now())
  isActive          Boolean   @default(true)
  lastLoginAt       DateTime?
  resetToken        String?   // 密码重置令牌
  resetTokenExpires DateTime? // 重置令牌过期时间
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  products   Product[]
  demands    Demand[]
  inquiries  Inquiry[]
  creditTransactions CreditTransaction[]
  certifications Certification[]
  favorites  Favorite[]
  savedSearches SavedSearch[]
  sellerRatingsReceived SellerRating[] @relation("SellerRatingsReceived")
  sellerRatingsGiven  SellerRating[]   @relation("SellerRatingsGiven")
  inspectionReports InspectionReport[]
  following   Follow[]  @relation("FollowFollower")
  followers   Follow[]  @relation("FollowSeller")
  contractsAsSeller ElectronicContract[] @relation("ContractSeller")
  contractsAsBuyer  ElectronicContract[] @relation("ContractBuyer")
  auctionsAsSeller  Auction[] @relation("AuctionSeller")
  auctionsAsWinner  Auction[] @relation("AuctionWinner")
  auctionBids       Bid[]     @relation("AuctionBidder")
  loanApplications  LoanApplication[]
  apiKeys           ApiKey[]
  rentalListings    RentalListing[]
  escrowAsBuyer     EscrowOrder[] @relation("EscrowBuyer")
  escrowAsSeller    EscrowOrder[] @relation("EscrowSeller")
}

model Brand {
  id            String @id @default(cuid())
  nameZh        String
  nameEn        String
  nameRu        String @default("")
  nameEs        String @default("")
  namePt        String @default("")
  nameAr        String @default("")
  nameFr        String @default("")
  nameHi        String @default("")
  originCountry String
  isImported    Boolean @default(false)

  products    Product[]
  valuations  Valuation[]
  demands     Demand[]
}

model Category {
  id       String  @id @default(cuid())
  nameZh   String
  nameEn   String
  nameRu   String @default("")
  nameEs   String @default("")
  namePt   String @default("")
  nameAr   String @default("")
  nameFr   String @default("")
  nameHi   String @default("")
  parentId String?

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  products Product[]
  demands  Demand[]
}

model Product {
  id            String   @id @default(cuid())
  sellerId      String
  brandId       String
  categoryId    String
  modelName     String
  year          Int
  workingHours  Int?
  condition     String   // excellent, good, fair, poor
  priceCny      Float
  priceUsd      Float?
  location      String
  descriptionZh String?
  descriptionEn String?
  descriptionRu String?
  descriptionEs String?
  descriptionPt String?
  descriptionAr String?
  descriptionFr String?
  descriptionHi String?
  aiGenerated   Boolean  @default(false)
  status        String   @default("active") // active, sold, draft, archived
  enginePower      Int?     // 额定马力 HP
  engineType       String?  // 发动机类型，默认 "Diesel Engine"
  driveSystem      String?  // 传动方式：2WD / 4WD / Full Hydraulic
  overallLength    Float?   // 长 mm
  overallWidth     Float?   // 宽 mm
  overallHeight    Float?   // 高 mm
  netWeight        Float?   // 整机重量 KG
  mainConfig       String?  // 主要配置描述
  priceMode        String   @default("por")  // "fixed" | "por"
  tradeTerm        String   @default("FOB")  // FOB / CIF / EXW
  tradePort        String?  // 发货港口
  standardDescriptionEn String? // 英文标准描述
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  seller  User          @relation(fields: [sellerId], references: [id])
  brand   Brand         @relation(fields: [brandId], references: [id])
  category Category     @relation(fields: [categoryId], references: [id])
  images              ProductImage[]
  videos              ProductVideo[]
  internationalPrices InternationalPrice[]
  inquiries           Inquiry[]
  arbitrageTopCaches   ArbitrageTopCache[]
  machineryIdentity   MachineryIdentity?
  inspectionReports   InspectionReport[]
  favorites           Favorite[]
  contracts           ElectronicContract[]
  auctions            Auction[]
  loanApplications    LoanApplication[]
  warranties          Warranty[]
  maintenanceRecords  MaintenanceRecord[]
  govMachineryData    GovMachineryData?
  blockchainRecords   BlockchainRecord[]
  rentalListing       RentalListing?
  escrowOrders        EscrowOrder[]
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)
  angleLabel String? // 拍摄角度标签

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductVideo {
  id        String  @id @default(cuid())
  productId String
  url       String
  sortOrder Int     @default(0)
  title     String?  // optional video title/caption

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Demand {
  id             String   @id @default(cuid())
  buyerId        String
  targetCountry  String
  categoryId     String?
  brandId        String?
  budgetMinUsd   Float?
  budgetMaxUsd   Float?
  quantity       Int      @default(1)
  deadlineMonths Int?
  description    String?
  status         String   @default("active") // active, fulfilled, closed
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  buyer    User      @relation(fields: [buyerId], references: [id])
  brand    Brand?    @relation(fields: [brandId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])
}

model Inquiry {
  id        String   @id @default(cuid())
  productId String
  buyerId   String?
  name      String
  email     String
  phone     String?
  company   String?
  message   String?
  status    String   @default("pending") // pending, replied, closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])
  buyer   User?   @relation(fields: [buyerId], references: [id])
}

model InternationalPrice {
  id              String   @id @default(cuid())
  productId       String
  priceForeignCny Float    // 国外市场价（人民币换算，万元）
  priceForeignRaw Float?   // 国外市场价（原始货币金额）
  currency        String   @default("EUR") // 原始货币：EUR, USD, etc.
  exchangeRate    Float?   // 当时汇率
  source          String   // 数据来源：e-farm, TractorHouse, Agroline, etc.
  sourceUrl       String?  // 来源链接
  sourceDate      String?  // 数据抓取日期
  country         String?  // 国外市场国家
  notes           String?  // 备注
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  isActive        Boolean  @default(true)
  confidenceScore Float    @default(0.5)
  lastVerified    DateTime?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Valuation {
  id               String  @id @default(cuid())
  productId        String?
  brandId          String
  modelName        String
  year             Int
  workingHours     Int?
  estimatedPriceCny Float
  estimatedPriceUsd Float
  confidenceScore  Float   @default(0.5)
  factors          String?  // JSON string (SQLite compat)

  brand Brand @relation(fields: [brandId], references: [id])
}

model CreditTransaction {
  id        String   @id @default(cuid())
  userId    String
  type      String   // consume, recharge, reward, expire
  amount    Int      // 正=入账，负=扣款
  balance   Int      // 操作后余额
  reason    String?  // 消费原因：valuation, publish_product, etc.
  relatedId String? // 关联对象ID
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// 汇率表 - 存储最新和历史汇率
model ExchangeRate {
  id            String   @id @default(cuid())
  baseCurrency  String   @default("CNY")  // 基础货币
  targetCurrency String  // 目标货币: USD, EUR, GBP等
  rate          Float    // 汇率值 (1 CNY = X USD)
  source        String   @default("exchangerate-api") // 数据来源
  lastUpdated   DateTime @default(now()) // 最后更新时间
  effectiveDate DateTime // 汇率生效日期
  
  @@unique([baseCurrency, targetCurrency, effectiveDate])
  @@index([baseCurrency, targetCurrency])
}

// 套利计算结果缓存表 - 预计算Top N设备
model ArbitrageTopCache {
  id            String   @id @default(cuid())
  productId     String   // 产品ID
  rank          Int      // 排名 (1-10)
  domesticPrice Float    // 国内价格(CNY)
  foreignPrice  Float    // 国外价格(CNY)
  priceDiff     Float    // 价差(CNY)
  priceDiffPercent Float // 价差百分比(%)
  profitMargin  Float?   // 利润率(%)
  lastCalculated DateTime @default(now()) // 最后计算时间
  validUntil    DateTime // 有效期至

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, rank])
  @@index([rank])
  @@index([validUntil])
}

// 文章/博客 - SEO驱动的国际农机市场内容
model Article {
  id            String    @id @default(cuid())
  slug          String    @unique
  titleZh       String
  titleEn       String?
  titleRu       String?
  titleEs       String?
  titlePt       String?
  titleAr       String?
  titleFr       String?
  titleHi       String?
  contentZh     String    @db.Text
  contentEn     String?   @db.Text
  contentRu     String?   @db.Text
  contentEs     String?   @db.Text
  contentPt     String?   @db.Text
  contentAr     String?   @db.Text
  contentFr     String?   @db.Text
  contentHi     String?   @db.Text
  excerptZh     String?   @db.Text   // 摘要/简介
  excerptEn     String?   @db.Text
  excerptRu     String?   @db.Text
  excerptEs     String?   @db.Text
  excerptPt     String?   @db.Text
  excerptAr     String?   @db.Text
  excerptFr     String?   @db.Text
  excerptHi     String?   @db.Text
  coverImage    String?              // 封面图URL
  status        String    @default("draft")  // draft, published, archived
  category      String?              // market-analysis, price-guide, brand-review, industry-news, buying-guide
  tags          String?   @db.Text   // JSON数组字符串 (中文) ["CLAAS","青储机","套利"]
  tagsEn        String?   @db.Text   // 英文标签: ["CLAAS","Forage Harvester","Arbitrage"]
  tagsRu        String?   @db.Text   // 俄文标签: ["CLAAS","Кормоуборочный","Арбитраж"]
  tagsEs        String?   @db.Text
  tagsPt        String?   @db.Text
  tagsAr        String?   @db.Text
  tagsFr        String?   @db.Text
  tagsHi        String?   @db.Text
  sourcePlatform String?             // 数据来源平台: agroline, machinerypete, tractorhouse, mascus, e-farm, internal
  sourceUrl     String?              // 原始数据来源URL
  metaTitle     String?              // SEO标题
  isPinned      Boolean   @default(false)  // 置顶标记
  metaDesc      String?              // SEO描述
  keywords      String?              // SEO关键词
  publishedAt   DateTime?
  viewCount     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, publishedAt])
  @@index([category])
  @@index([sourcePlatform])
}

// 市场情报速递 - 每日更新
model MarketIntel {
  id              String   @id @default(cuid())
  date            DateTime // 数据日期（每日一条）
  icon            String   // emoji图标
  region          String   // 地区（中文）
  regionEn        String?  // 地区（英文）
  regionRu        String?  // 地区（俄文）
  regionEs        String?  // 地区（西班牙语）
  regionPt        String?  // 地区（葡萄牙语）
  regionAr        String?  // 地区（阿拉伯语）
  regionFr        String?  // 地区（法语）
  regionHi        String?  // 地区（印地语）
  tags            String   // JSON数组: ["tag1","tag2"] (中文)
  tagsEn          String?  @db.Text // 英文标签JSON
  tagsRu          String?  @db.Text // 俄文标签JSON
  tagsEs          String?  @db.Text // 西班牙语标签JSON
  tagsPt          String?  @db.Text // 葡萄牙语标签JSON
  tagsAr          String?  @db.Text // 阿拉伯语标签JSON
  tagsFr          String?  @db.Text // 法语标签JSON
  tagsHi          String?  @db.Text // 印地语标签JSON
  text            String   // 摘要文本（中文）
  textEn          String?  // 摘要文本（英文）
  textRu          String?  // 摘要文本（俄文）
  textEs          String?  // 摘要文本（西班牙语）
  textPt          String?  // 摘要文本（葡萄牙语）
  textAr          String?  // 摘要文本（阿拉伯语）
  textFr          String?  // 摘要文本（法语）
  textHi          String?  // 摘要文本（印地语）
  url             String?  // 链接
  detailedContent String?  // 展开后的Markdown内容（中文）
  detailedContentEn String? @db.Text // 展开后的Markdown内容（英文）
  detailedContentRu String? @db.Text // 展开后的Markdown内容（俄文）
  detailedContentEs String? @db.Text // 展开后的Markdown内容（西班牙语）
  detailedContentPt String? @db.Text // 展开后的Markdown内容（葡萄牙语）
  detailedContentAr String? @db.Text // 展开后的Markdown内容（阿拉伯语）
  detailedContentFr String? @db.Text // 展开后的Markdown内容（法语）
  detailedContentHi String? @db.Text // 展开后的Markdown内容（印地语）
  dataSummary     String?  // JSON: [{"label":"...","value":"..."}]
  actionTips      String?  // JSON数组: ["tip1","tip2"]
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
  @@index([isActive, date])
}

// ── 多语客服 Agent 对话表 ──
model ChatSession {
  id        String   @id @default(cuid())
  visitorId String   // 匿名访客指纹或登录用户ID
  productId String?  // 关联产品（如果从产品页发起）
  locale    String   @default("en") // zh, en, ru, es, pt, ar, fr, hi
  status    String   @default("active") // active, closed, handed_over
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]

  @@index([visitorId, status])
  @@index([productId])
  @@index([updatedAt])
}

// ── 卖方采集原始数据表 ──
model RawListing {
  id            String   @id @default(cuid())
  source        String   // 来源：agriaffaires, tractorhouse, nongjitong, etc.
  sourceUrl     String   // 原始链接
  status        String   @default("pending") // pending, reviewed, approved, rejected
  
  // 产品信息（采集原始数据）
  brandName     String   // 品牌名（原始文本，未映射到 Brand 表）
  modelName     String   // 型号
  year          Int?     // 年份
  workingHours  Int?     // 工作小时
  condition     String?  // 状况描述
  priceRaw      Float?   // 原始价格
  currency      String?  // 原始货币
  priceCny      Float?   // 换算人民币
  location      String   // 地区
  
  // 卖家信息
  sellerName    String?  // 卖家名
  sellerPhone   String?  // 电话
  sellerWechat  String?  // 微信
  sellerWhatsapp String? // WhatsApp
  
  // 图片
  images        String?  // JSON 数组：["url1", "url2"]
  
  // 去重
  contentHash   String   @unique // MD5(brand+model+year+location+price)
  
  // 元数据
  scrapedAt     DateTime @default(now())
  reviewedAt    DateTime?
  reviewedBy    String?  // 审核人ID
  notes         String?  // 审核备注
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([status, scrapedAt])
  @@index([source, scrapedAt])
  @@index([contentHash])
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String   // user, assistant, system, human
  content   String   @db.Text
  intent    String?  // 意图分类：price_inquiry, product_compare, shipping, payment, warranty, general, hand_over
  metadata  String?  // JSON: { productIds: [...], confidence: 0.92, model: "openrouter/..." }
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

// ═══════════════════════════════════════════════════════
// #0 调度者 Agent — 数据模型
// ═══════════════════════════════════════════════════════

model AgentDefinition {
  id          String   @id @default(cuid())
  agentId     String   @unique // 唯一标识：price-intel, buyer-chat, seller-scout, seller-helper
  name        String   // 显示名称
  description String?  // 描述
  version     String   @default("0.1.0")
  
  // 触发方式
  triggerType String   @default("manual") // manual, cron, webhook, dependency
  schedule    String?  // cron 表达式（如 "0 6 * * *"）
  endpoint    String?  // API 端点（如 "/api/agents/price-intel"）
  
  // 依赖：此 Agent 执行前需要先执行哪些 Agent
  dependencies String? // JSON 数组：["seller-scout", ...]
  
  // 状态
  status      String   @default("active") // active, paused, disabled, error
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  
  // 配置
  config      String?  // JSON：各 Agent 自定义配置
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  runs        AgentRunLog[]
  
  @@index([status, agentId])
}

model AgentRunLog {
  id          String   @id @default(cuid())
  agentId     String
  
  // 执行信息
  triggeredBy String   @default("manual") // manual, cron, dependency, webhook, system
  status      String   // running, success, failed, cancelled, timeout
  
  // 时间
  startedAt   DateTime @default(now())
  completedAt DateTime?
  durationMs  Int?     // 执行耗时（毫秒）
  
  // 结果
  result      String?  // JSON：成功时的返回数据摘要
  errorMessage String? // 失败时的错误信息
  
  // 元数据
  metadata    String?  // JSON：额外信息（如触发参数、输入摘要）
  
  createdAt   DateTime @default(now())
  
  agent       AgentDefinition @relation(fields: [agentId], references: [agentId], onDelete: Cascade)
  
  @@index([agentId, startedAt])
  @@index([status, startedAt])
}

// ═══════════════════════════════════════════════════════
// 一机一码身份溯源系统
// ═══════════════════════════════════════════════════════

model MachineryIdentity {
  id          String   @id @default(cuid())
  productId   String   @unique
  qrCode      String   @unique // 唯一QR码标识：SD-YYYY-XXXXXXX
  serialNo    String?  // 出厂编号/铭牌编号
  manufactureDate String? // 出厂日期
  factoryName String?  // 制造商
  factoryLocation String? // 产地
  verifyHash  String?  // 防伪校验哈希
  isVerified  Boolean  @default(false) // 是否已验证
  verifiedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  events  MachineryEvent[]

  @@index([qrCode])
}

model MachineryEvent {
  id          String   @id @default(cuid())
  identityId  String
  eventType   String   // manufactured, listed, inspected, traded, exported, maintained, transferred
  title       String
  description String?
  operator    String?  // 操作人/机构
  location    String?  // 事件发生地
  evidence    String?  // JSON: 证据文件URL数组
  metadata    String?  // JSON: 额外元数据
  eventDate   DateTime @default(now()) // 事件发生时间
  createdAt   DateTime @default(now())

  identity MachineryIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@index([identityId, eventDate])
  @@index([eventType])
}

// ═══════════════════════════════════════════════════════
// 三重认证体系
// ═══════════════════════════════════════════════════════

model Certification {
  id              String   @id @default(cuid())
  userId          String   // 申请用户ID
  certType        String   // institution(机构认证), personnel(人员认证), vehicle(车辆认证)
  status          String   @default("pending") // pending, approved, rejected, expired
  // 通用字段
  applicantName   String   // 申请人/机构名称
  contactPhone    String
  contactEmail    String?

  // 机构认证字段
  businessLicenseNo  String?  // 营业执照号
  businessLicenseImg String?  // 营业执照图片URL
  legalPerson     String?  // 法人代表
  registeredCapital String? // 注册资本
  businessScope   String?  // 经营范围

  // 人员认证字段
  personnelName   String?  // 评估师姓名
  personnelCertNo String?  // 证书编号
  personnelCertImg String? // 证书图片URL
  personnelLevel  String?  // 评估师等级：初级/中级/高级

  // 车辆认证字段
  productId       String?  // 关联产品ID
  inspectionReportNo String? // 检测报告编号
  inspectionReportImg String? // 检测报告图片URL
  inspectionGrade String?  // 检测等级：A/B/C/D
  inspectionDate  DateTime? // 检测日期
  inspectionOrg   String?  // 检测机构

  // 审核信息
  reviewedBy      String?  // 审核人ID
  reviewedAt      DateTime?
  reviewNote      String?  // 审核备注
  validUntil      DateTime? // 认证有效期

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, certType])
  @@index([status])
  @@index([certType, status])
}

// ═══════════════════════════════════════════════════════
// 线下服务网络
// ═══════════════════════════════════════════════════════

model ServiceCenter {
  id            String   @id @default(cuid())
  name          String   // 网点名称
  level         String   @default("county") // province(省级中心), city(市级), county(县域网点)
  province      String   // 省份
  city          String?  // 城市
  district      String?  // 区县
  address       String   // 详细地址
  longitude     Float?   // 经度
  latitude      Float?   // 纬度
  contactPerson String?  // 联系人
  contactPhone  String?  // 联系电话
  services      String?  // JSON: 服务项目数组 ["检测","维修","评估","交易"]
  businessHours String?  // 营业时间
  images        String?  // JSON: 网点图片URL数组
  description   String?  // 网点描述
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([province, level])
  @@index([isActive])
  @@index([level, isActive])

  maintenanceRecords MaintenanceRecord[]
}

// ═══════════════════════════════════════════════════════
// 设备检验报告
// ═══════════════════════════════════════════════════════

model InspectionReport {
  id              String   @id @default(cuid())
  productId       String
  inspectorId     String?  // 检验员ID（平台人员）
  inspectorName   String   // 检验员姓名
  inspectionOrg   String?  // 检验机构
  inspectionDate  DateTime @default(now())
  overallGrade    String   // A(优秀) / B(良好) / C(一般) / D(需维修)
  overallScore    Int      // 0-100 综合评分
  // 5大类检测项（JSON数组）
  // [
  //   { category: "engine", items: [{ name, result, score, note }] },
  //   { category: "transmission", items: [...] },
  //   { category: "hydraulics", items: [...] },
  //   { category: "electrical", items: [...] },
  //   { category: "exterior", items: [...] }
  // ]
  inspectionItems String   // JSON: 5大类20项检测结果
  summary         String?  // 检验总结
  recommendations String?  // 维修建议
  photos          String?  // JSON: 检验照片URL数组
  reportPdfUrl    String?  // PDF报告URL
  status          String   @default("published") // draft, published, archived
  validUntil      DateTime? // 报告有效期
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  inspector User?   @relation(fields: [inspectorId], references: [id])

  @@index([productId])
  @@index([overallGrade])
  @@index([status, inspectionDate])
}

// ═══════════════════════════════════════════════════════
// 收藏 / 关注 / 保存搜索
// ═══════════════════════════════════════════════════════

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId, createdAt])
}

model Follow {
  id                  String   @id @default(cuid())
  userId              String   // 关注者
  sellerId            String   // 被关注的卖家
  notificationEnabled Boolean  @default(true)
  createdAt           DateTime @default(now())

  user   User @relation("FollowFollower", fields: [userId], references: [id], onDelete: Cascade)
  seller User @relation("FollowSeller", fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([userId, sellerId])
  @@index([userId, createdAt])
  @@index([sellerId])
  @@index([notificationEnabled])
}

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  name      String   // 搜索名称
  filters   String   // JSON: 筛选条件
  notifyOnNew Boolean @default(false) // 新品上架通知
  lastNotifiedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ═══════════════════════════════════════════════════════
// 卖家信任体系 — 评分
// ═══════════════════════════════════════════════════════

model SellerRating {
  id          String   @id @default(cuid())
  sellerId    String   // 被评价的卖家
  raterId     String   // 评价人
  productId   String?  // 关联产品（交易后评价）
  score       Int      // 1-5 星
  comment     String?
  // 评价维度
  itemMatchScore  Int? // 物品相符度 1-5
  serviceScore    Int? // 服务态度 1-5
  logisticsScore  Int? // 物流速度 1-5
  createdAt   DateTime @default(now())

  seller User @relation("SellerRatingsReceived", fields: [sellerId], references: [id], onDelete: Cascade)
  rater  User @relation("SellerRatingsGiven", fields: [raterId], references: [id], onDelete: Cascade)

  @@unique([sellerId, raterId, productId])
  @@index([sellerId, createdAt])
  @@index([raterId])
}

// ═══════════════════════════════════════════════════════
// 价格指数引擎
// ═══════════════════════════════════════════════════════

model PriceIndex {
  id            String   @id @default(cuid())
  date          DateTime // 数据日期
  category      String?  // 品类ID（null=综合指数）
  brand         String?  // 品牌ID（null=品类或综合）
  region        String?  // 区域（null=全国）
  indexValue    Float    // 指数值（基准日=100）
  avgPriceCny   Float    // 平均价格（万元）
  sampleCount   Int      // 样本数量
  monthOverMonth Float?  // 环比变化(%)
  yearOverYear  Float?   // 同比变化(%)
  metadata      String?  // JSON: 额外元数据
  createdAt     DateTime @default(now())

  @@unique([date, category, brand, region])
  @@index([date])
  @@index([category, date])
  @@index([brand, date])
}

// ═══════════════════════════════════════════════════════
// 行业报告
// ═══════════════════════════════════════════════════════

model IndustryReport {
  id            String    @id @default(cuid())
  title         String    // 报告标题
  reportType    String    // monthly, quarterly, yearly, special
  period        String    // 报告期：2026-07, 2026-Q3, 2026
  summary       String    @db.Text // 报告摘要
  content       String    @db.Text // Markdown内容
  coverImage    String?   // 封面图URL
  // 关键数据摘要
  keyMetrics    String?   // JSON: [{label, value, change}]
  topBrands     String?   // JSON: [{brand, share, avgPrice}]
  topCategories String?   // JSON: [{category, count, avgPrice}]
  priceTrends   String?   // JSON: [{date, index}]
  // 状态
  status        String    @default("draft") // draft, published, archived
  publishedAt   DateTime?
  viewCount     Int       @default(0)
  downloadCount Int       @default(0)
  // 作者
  authorId      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, publishedAt])
  @@index([reportType, period])
}

// ═══════════════════════════════════════════════════════
// 电子合同
// ═══════════════════════════════════════════════════════

model ElectronicContract {
  id              String   @id @default(cuid())
  contractNo      String   @unique // 合同编号：SD-HT-YYYYMMDD-XXXX
  productId       String   // 关联产品
  sellerId        String   // 卖方ID
  buyerId         String   // 买方ID
  // 合同信息
  title           String   // 合同标题
  contractType    String   @default("sale") // sale(买卖), auction(拍卖), lease(租赁)
  tradeTerm       String   @default("FOB") // 贸易条款
  // 交易信息
  productInfo     String   // JSON: 产品摘要信息
  priceCny        Float    // 成交价（人民币）
  priceUsd        Float?   // 成交价（美元）
  currency        String   @default("CNY")
  paymentMethod   String?  // 付款方式
  deliveryDate    DateTime? // 交货日期
  deliveryAddress String?  // 交货地址
  // 合同条款
  terms           String   @db.Text // 合同条款（Markdown）
  attachments     String?  // JSON: 附件URL数组
  // 签署状态
  status          String   @default("draft") // draft, pending_seller, pending_buyer, signed, executed, cancelled, disputed
  sellerSignedAt  DateTime?
  buyerSignedAt   DateTime?
  sellerSignature String?  // 签名图片URL或哈希
  buyerSignature  String?  // 签名图片URL或哈希
  // PDF
  pdfUrl          String?  // 生成的PDF URL
  // 时间
  validFrom       DateTime?
  validUntil      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])
  seller  User    @relation("ContractSeller", fields: [sellerId], references: [id])
  buyer   User    @relation("ContractBuyer", fields: [buyerId], references: [id])
  warranties Warranty[]

  @@index([sellerId, status])
  @@index([buyerId, status])
  @@index([productId])
  @@index([status, createdAt])
}

// ═══════════════════════════════════════════════════════
// 在线拍卖系统
// ═══════════════════════════════════════════════════════

model Auction {
  id              String   @id @default(cuid())
  auctionNo       String   @unique // 拍卖编号：SD-PM-YYYYMMDD-XXXX
  productId       String   // 拍卖设备
  sellerId        String   // 卖方
  title           String   // 拍卖标题
  description     String?  @db.Text // 拍卖描述
  // 拍卖参数
  startPrice      Float    // 起拍价（CNY）
  reservePrice    Float?   // 保留价（CNY），未达则流拍
  priceIncrement  Float    @default(1000) // 每次加价幅度
  deposit         Float    @default(0) // 参拍保证金
  // 时间
  startTime       DateTime // 拍卖开始时间
  endTime         DateTime // 拍卖结束时间
  // 状态
  status          String   @default("scheduled") // scheduled, live, ended, cancelled, settled
  winnerId        String?  // 中标者ID
  winningBid      Float?   // 中标价
  totalBids       Int      @default(0) // 总出价次数
  totalBidders    Int      @default(0) // 参拍人数
  // 结算
  settledAt       DateTime?
  contractId      String?  // 关联合同ID
  // 元数据
  coverImage      String?  // 封面图
  viewCount       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])
  seller  User    @relation("AuctionSeller", fields: [sellerId], references: [id])
  bids    Bid[]
  winner  User?   @relation("AuctionWinner", fields: [winnerId], references: [id])

  @@index([status, endTime])
  @@index([sellerId])
  @@index([productId])
}

model Bid {
  id          String   @id @default(cuid())
  auctionId   String
  bidderId    String
  amount      Float    // 出价金额
  isWinning   Boolean  @default(false)
  createdAt   DateTime @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bidder  User    @relation("AuctionBidder", fields: [bidderId], references: [id], onDelete: Cascade)

  @@index([auctionId, amount])
  @@index([bidderId])
}

// ═══════════════════════════════════════════════════════
// 金融保险服务
// ═══════════════════════════════════════════════════════

model FinancialService {
  id              String   @id @default(cuid())
  serviceName     String   // 产品名称
  serviceType     String   // loan(贷款), insurance(保险), lease(租赁)
  provider        String   // 机构名称：银行/保险公司
  providerLogo    String?  // 机构Logo URL
  // 产品参数
  interestRate    Float?   // 利率(%)
  maxAmount       Float?   // 最高额度（CNY）
  maxTerm         Int?     // 最长期限（月）
  downPayment     Float?   // 首付比例(%)
  coverage        String?  @db.Text // 保险保障范围
  premium         Float?   // 保费率(%)
  // 描述
  description     String?  @db.Text
  requirements    String?  @db.Text // 申请条件
  // 状态
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  applications LoanApplication[]

  @@index([serviceType, isActive])
}

model LoanApplication {
  id              String   @id @default(cuid())
  userId          String   // 申请人
  serviceId       String   // 关联金融产品
  productId       String?  // 关联设备（如购买设备贷款）
  // 申请信息
  applicantName   String
  contactPhone    String
  contactEmail    String?
  companyName     String?
  // 贷款/保险信息
  appliedAmount   Float    // 申请金额
  appliedTerm     Int?     // 申请期限（月）
  purpose         String?  @db.Text // 贷款用途/保险需求
  // 资料
  idCardUrl       String?  // 身份证/营业执照URL
  assetProofUrl   String?  // 资产证明URL
  // 状态
  status          String   @default("pending") // pending, reviewing, approved, rejected, disbursed
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewNote      String?
  approvedAmount  Float?   // 实批金额
  // 元数据
  metadata        String?  // JSON
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  service FinancialService @relation(fields: [serviceId], references: [id])
  product Product?         @relation(fields: [productId], references: [id])

  @@index([userId, status])
  @@index([status, createdAt])
}

// ═══════════════════════════════════════════════════════
// 售后维保平台
// ═══════════════════════════════════════════════════════

model Warranty {
  id              String   @id @default(cuid())
  productId       String   // 关联设备
  contractId      String?  // 关联合同
  warrantyType    String   // standard(标准质保), extended(延保), parts(配件质保)
  coverage        String   @db.Text // 保障范围
  startDate       DateTime
  endDate         DateTime
  status          String   @default("active") // active, expired, claimed
  provider        String?  // 质保方
  terms           String?  @db.Text // 质保条款
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product   Product           @relation(fields: [productId], references: [id])
  contract  ElectronicContract? @relation(fields: [contractId], references: [id])
  records   MaintenanceRecord[]

  @@index([productId, status])
  @@index([endDate])
}

model MaintenanceRecord {
  id              String   @id @default(cuid())
  productId       String   // 关联设备
  warrantyId      String?  // 关联质保
  serviceCenterId String?  // 服务网点
  // 维保信息
  maintenanceType String   // routine(日常保养), repair(维修), inspection(检测), emergency(紧急维修)
  title           String   // 维保标题
  description     String?  @db.Text
  cost            Float?   // 费用（CNY）
  // 状态
  status          String   @default("scheduled") // scheduled, in_progress, completed, cancelled
  scheduledDate   DateTime?
  completedDate   DateTime?
  // 维修人员
  technician      String?  // 维修技师
  // 记录
  partsReplaced   String?  @db.Text // 更换配件（JSON数组）
  photos          String?  // JSON: 维修照片URL数组
  notes           String?  @db.Text // 维修备注
  // 评价
  rating          Int?     // 1-5 评分
  ratingComment   String?  // 评价内容
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product       Product        @relation(fields: [productId], references: [id])
  warranty      Warranty?      @relation(fields: [warrantyId], references: [id])
  serviceCenter ServiceCenter? @relation(fields: [serviceCenterId], references: [id])

  @@index([productId, status])
  @@index([status, scheduledDate])
}

// ═══════════════════════════════════════════════════════
// 第四阶段：开放API + 政府数据 + 海外仓 + 区块链 + 租赁
// ═══════════════════════════════════════════════════════

// 开放API Key管理
model ApiKey {
  id              String   @id @default(cuid())
  key             String   @unique // 实际API Key
  userId          String   // 所属用户
  name            String   // Key名称（如"农业部数据接口"）
  organization    String?  // 机构名称
  scope           String   @default("read") // read, read_write, admin
  // 速率限制
  rateLimitPerHour Int     @default(100)
  rateLimitPerDay  Int     @default(1000)
  // 使用统计
  totalRequests   Int      @default(0)
  lastUsedAt      DateTime?
  // 状态
  status          String   @default("active") // active, suspended, revoked
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status])
}

// 政府农机补贴政策
model GovSubsidyPolicy {
  id              String   @id @default(cuid())
  title           String   // 政策标题
  policyNumber    String?  // 政策文号
  region          String   // 适用地区（省份/全国）
  // 补贴详情
  category        String   // 补贴类别: purchase(购机), scrap(报废), operation(作业), loan(贷款贴息)
  machineryTypes  String?  // 适用机型（JSON数组）
  subsidyAmount   Float?   // 补贴金额（元）
  subsidyRatio    Float?   // 补贴比例（如0.3 = 30%）
  maxSubsidy      Float?   // 最高补贴额
  // 时间
  effectiveDate   DateTime
  expiryDate      DateTime?
  // 内容
  description     String   @db.Text
  requirements    String?  @db.Text // 申请条件
  applicationUrl  String?  // 官方申请链接
  source          String?  // 数据来源
  status          String   @default("active") // active, expired, repealed
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([region, status])
  @@index([category, status])
  @@index([effectiveDate])
}

// 政府农机登记数据
model GovMachineryData {
  id              String   @id @default(cuid())
  productId       String?  @unique // 关联平台产品（可选）
  // 登记信息
  registrationNo  String?  // 登记编号
  plateNumber     String?  // 牌照号
  ownerName       String?  // 登记所有人
  // 设备信息
  brandName       String
  modelName       String
  category        String   // 设备类别
  enginePower     Float?   // 发动机功率
  // 合规信息
  emissionStandard String? // 排放标准
  inspectionDate   DateTime? // 年检日期
  inspectionResult String?  // 检验结果
  // 状态
  registrationStatus String? @default("active") // active, transferred, scrapped
  // 元数据
  dataSource      String   @default("gov_registry")
  verifiedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product Product? @relation(fields: [productId], references: [id])

  @@index([brandName, category])
  @@index([registrationNo])
}

// 海外仓信息
model OverseasWarehouse {
  id              String   @id @default(cuid())
  name            String   // 仓库名称
  nameEn          String   @default("")
  country         String   // 所在国家
  city            String   // 所在城市
  address         String   // 详细地址
  // 仓库属性
  warehouseType   String   // bonded(保税仓), standard(普通仓), cold(冷链仓)
  capacity        Float?   // 容量（立方米）
  area            Float?   // 面积（平方米）
  // 服务
  services        String?  @db.Text // 服务内容（JSON数组）
  // 联系
  contactName     String?
  contactPhone    String?
  contactEmail    String?
  // 位置
  latitude        Float?
  longitude       Float?
  // 状态
  status          String   @default("active") // active, inactive, full
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([country, status])
  @@index([warehouseType, status])
}

// 区块链溯源记录
model BlockchainRecord {
  id              String   @id @default(cuid())
  productId       String   // 关联产品
  // 区块信息
  blockIndex      Int      // 区块序号
  previousHash    String   // 前一区块哈希
  currentHash     String   // 当前区块哈希
  // 事件数据
  eventType       String   // created, inspected, transferred, maintained, sold, exported
  eventData       String   @db.Text // JSON: 事件详细数据
  timestamp       DateTime @default(now())
  // 签名
  operatorId      String?  // 操作人ID
  operatorName    String?  // 操作人名称
  // 验证
  isVerified      Boolean  @default(false)
  verifiedAt      DateTime?
  createdAt       DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, blockIndex])
  @@index([currentHash])
}

// 租赁信息
model RentalListing {
  id              String   @id @default(cuid())
  productId       String   @unique // 关联产品
  ownerId         String   // 出租方（卖家）
  // 租赁模式
  rentalType      String   // daily(日租), monthly(月租), yearly(年租)
  pricePerDay     Float?   // 日租金（CNY）
  pricePerMonth   Float?   // 月租金（CNY）
  pricePerYear    Float?   // 年租金（CNY）
  deposit         Float?   // 押金（CNY）
  // 租赁条件
  minRentalPeriod Int?     // 最短租赁周期
  maxRentalPeriod Int?     // 最长租赁周期
  // 配送
  deliveryAvailable Boolean @default(false)
  deliveryFee       Float?  // 配送费
  // 状态
  status          String   @default("available") // available, rented, unavailable
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  owner   User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([status, rentalType])
  @@index([ownerId, status])
}

// ═══════════════════════════════════════════════════════
// 担保交易系统（Escrow）
// ═══════════════════════════════════════════════════════

model EscrowOrder {
  id              String   @id @default(cuid())
  orderNo         String   @unique // 订单号：SD-ESC-YYYYMMDD-XXXXXX
  productId       String   // 关联产品
  buyerId         String   // 买方
  sellerId        String   // 卖方
  // 金额信息
  amount          Float    // 交易总额（CNY）
  platformFee     Float    @default(0) // 平台手续费
  sellerAmount    Float    @default(0) // 卖家实际到账
  // 支付信息
  paymentMethod   String   // wechat, alipay
  paymentStatus   String   @default("pending") // pending, paid, escrow, released, refunded, cancelled
  // 时间线
  paidAt          DateTime?
  escrowStartedAt DateTime?
  releasedAt      DateTime?
  refundedAt      DateTime?
  cancelledAt     DateTime?
  // 确认收货
  buyerConfirmed  Boolean  @default(false)
  buyerConfirmedAt DateTime?
  // 自动放款倒计时（确认收货后X天自动放款）
  autoReleaseAt   DateTime?
  // 物流
  deliveryAddress String?  @db.Text
  deliveryCompany String?
  trackingNo      String?
  shippedAt       DateTime?
  // 争议
  disputeStatus   String?  // null, opened, resolved_buyer, resolved_seller
  disputeReason   String?  @db.Text
  disputeOpenedAt DateTime?
  // 元数据
  metadata        String?  @db.Text // JSON
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product   Product       @relation(fields: [productId], references: [id])
  buyer     User          @relation("EscrowBuyer", fields: [buyerId], references: [id])
  seller    User          @relation("EscrowSeller", fields: [sellerId], references: [id])
  payments  PaymentRecord[]

  @@index([buyerId, paymentStatus])
  @@index([sellerId, paymentStatus])
  @@index([productId])
  @@index([paymentStatus, createdAt])
  @@index([autoReleaseAt])
}

model PaymentRecord {
  id              String   @id @default(cuid())
  orderId         String   // 关联担保订单
  paymentMethod   String   // wechat, alipay
  // 第三方流水
  transactionId   String?  // 微信/支付宝流水号
  prepayId        String?  // 微信预支付ID
  tradeNo         String?  // 支付宝交易号
  // 金额
  amount          Float    // 支付金额（CNY）
  // 状态
  status          String   @default("pending") // pending, success, failed, refunded
  // 原始数据
  rawRequest      String?  @db.Text // JSON: 请求参数
  rawResponse     String?  @db.Text // JSON: 响应数据
  rawCallback     String?  @db.Text // JSON: 回调数据
  // 时间
  paidAt          DateTime?
  callbackAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  order EscrowOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([transactionId])
  @@index([status])
}
