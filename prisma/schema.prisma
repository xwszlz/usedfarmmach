generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String               @id @default(cuid())
  email                 String?              @unique
  phone                 String?
  /// 邮箱待补全标记：小程序无邮箱注册自动置 true；web 注册有邮箱则 false
  emailPending          Boolean              @default(false)
  /// 邮箱是否已验证：阶段0补全即视为已验证（自证）；阶段1改为令牌验证后置 true
  emailVerified         Boolean              @default(false)
  /// 数据出境单独同意时间（留痕合规证据，比仅校验更强）
  consentCrossBorderAt  DateTime?
  passwordHash          String
  role                  String               @default("buyer")
  companyName           String?
  country               String?
  preferredLanguage     String               @default("zh")
  credits               Int                  @default(0)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  freeValuationsResetAt DateTime             @default(now())
  freeValuationsUsed    Int                  @default(0)
  isActive              Boolean              @default(true)
  lastLoginAt           DateTime?
  membershipExpiresAt   DateTime?
  membershipTier        String               @default("free")
  username              String?              @unique
  resetToken            String?
  resetTokenExpires     DateTime?
  wxOpenid              String?
  miniOpenid            String?              @unique
  inviteCode            String?              @unique
  invitedViaCode        String?
  lifetime              Boolean              @default(false)
  badges                String[]             @default([])
  deviceFingerprint     String?
  registerIp            String?
  apiKeys               ApiKey[]
  auctionsAsSeller      Auction[]            @relation("AuctionSeller")
  auctionsAsWinner      Auction[]            @relation("AuctionWinner")
  auctionBids           Bid[]                @relation("AuctionBidder")
  expoBooths            Booth[]
  certifications        Certification[]
  creditTransactions    CreditTransaction[]
  creditLots            CreditLot[]
  checkIns              CheckIn[]
  milestones            UserMilestone[]
  invitationsSent       Invitation[]          @relation("Inviter")
  invitationReceived    Invitation?           @relation("Invitee")
  serviceOrders         ServiceOrder[]
  promotions            Promotion[]
  demands               Demand[]
  contractsAsBuyer      ElectronicContract[] @relation("ContractBuyer")
  contractsAsSeller     ElectronicContract[] @relation("ContractSeller")
  escrowAsBuyer         EscrowOrder[]        @relation("EscrowBuyer")
  escrowAsSeller        EscrowOrder[]        @relation("EscrowSeller")
  expoInquiries         ExpoInquiry[]
  favorites             Favorite[]
  followers             Follow[]             @relation("FollowSeller")
  following             Follow[]             @relation("FollowFollower")
  inquiries             Inquiry[]
  notifications         Notification[]
  inspectionBookings    InspectionBooking[]
  inspectionReports     InspectionReport[]
  loanApplications      LoanApplication[]
  expoOrdersAsBuyer     Order[]              @relation("OrderBuyer")
  expoOrdersAsSeller    Order[]              @relation("OrderSeller")
  products              Product[]
  expoQuotesAsBuyer     Quote[]              @relation("QuoteBuyer")
  expoQuotesAsSeller    Quote[]              @relation("QuoteSeller")
  rentalListings        RentalListing[]
  expoReviewsReceived   Review[]             @relation("ReviewReviewee")
  expoReviewsGiven      Review[]             @relation("ReviewReviewer")
  savedSearches         SavedSearch[]
  sellerRatingsGiven    SellerRating[]       @relation("SellerRatingsGiven")
  sellerRatingsReceived SellerRating[]       @relation("SellerRatingsReceived")
}

/// PII 访问审计：记录谁、何时、读了哪个用户的哪个 PII 字段、用途（保留 ≥6 个月）
model PiiAuditLog {
  id           String   @id @default(cuid())
  actorId      String   // 操作人（admin/super_admin）userId
  targetUserId String   // 被查看的用户
  field        String   // 如 "email" | "phone"
  action       String   @default("view_full") // view_full | export
  purpose      String?  // 用途备注（可选）
  createdAt    DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([targetUserId, createdAt])
}

model Brand {
  id              String         @id @default(cuid())
  nameZh          String
  nameEn          String
  originCountry   String
  isImported      Boolean        @default(false)
  nameRu          String         @default("")
  nameEs          String         @default("")
  namePt          String         @default("")
  nameAr          String         @default("")
  nameFr          String         @default("")
  nameHi          String         @default("")
  brandTier       String?
  establishedYear Int?
  expoCoverUrl    String?
  expoLogoUrl     String?
  expoSlug        String?        @unique
  expoStory       String?
  exportVolume    String?
  isChineseBrand  Boolean        @default(false)
  officialWebsite String?
  Booth           Booth[]
  demands         Demand[]
  products        Product[]
  showcaseItems   ShowcaseItem[]
  valuations      Valuation[]
}

model Category {
  id       String     @id @default(cuid())
  nameZh   String
  nameEn   String
  parentId String?
  nameRu   String     @default("")
  nameEs   String     @default("")
  namePt   String     @default("")
  nameAr   String     @default("")
  nameFr   String     @default("")
  nameHi   String     @default("")
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  demands  Demand[]
  products Product[]
}

model Product {
  id                    String               @id @default(cuid())
  sellerId              String
  brandId               String
  categoryId            String
  modelName             String
  year                  Int
  workingHours          Int?
  condition             String
  priceCny              Float
  priceUsd              Float?
  location              String
  descriptionZh         String?
  descriptionEn         String?
  aiGenerated           Boolean              @default(false)
  status                String               @default("active")
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  descriptionRu         String?
  descriptionEs         String?
  descriptionPt         String?
  descriptionAr         String?
  descriptionFr         String?
  descriptionHi         String?
  driveSystem           String?
  enginePower           Int?
  engineType            String?
  mainConfig            String?
  netWeight             Float?
  overallHeight         Float?
  overallLength         Float?
  overallWidth          Float?
  priceMode             String               @default("por")
  standardDescriptionEn String?
  tradePort             String?
  tradeTerm             String               @default("FOB")
  latitude              Float?
  longitude             Float?
  city                  String?
  country               String?
  province              String?
  promotedUntil         DateTime?
  promotedAt            DateTime?
  refreshedAt           DateTime?
  promotions            Promotion[]
  arbitrageTopCaches    ArbitrageTopCache[]
  auctions              Auction[]
  blockchainRecords     BlockchainRecord[]
  contracts             ElectronicContract[]
  escrowOrders          EscrowOrder[]
  favorites             Favorite[]
  govMachineryData      GovMachineryData?
  inquiries             Inquiry[]
  inspectionReports     InspectionReport[]
  internationalPrices   InternationalPrice[]
  loanApplications      LoanApplication[]
  machineryIdentity     MachineryIdentity?
  maintenanceRecords    MaintenanceRecord[]
  brand                 Brand                @relation(fields: [brandId], references: [id])
  category              Category             @relation(fields: [categoryId], references: [id])
  seller                User                 @relation(fields: [sellerId], references: [id])
  images                ProductImage[]
  videos                ProductVideo[]
  rentalListing         RentalListing?
  warranties            Warranty[]
}

model ProductImage {
  id         String  @id @default(cuid())
  productId  String
  url        String
  sortOrder  Int     @default(0)
  isPrimary  Boolean @default(false)
  angleLabel String?
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductVideo {
  id               String    @id @default(cuid())
  productId        String
  url              String
  sortOrder        Int       @default(0)
  title            String?
  duration         Int?
  fileSize         Int?
  moderatedAt      DateTime?
  moderationStatus String?   @default("pending")
  product          Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Subscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  source       String   @default("miniprogram")
  isActive     Boolean  @default(true)
  subscribedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
  @@index([isActive])
}

model Demand {
  id             String    @id @default(cuid())
  buyerId        String
  targetCountry  String
  categoryId     String?
  brandId        String?
  budgetMinUsd   Float?
  budgetMaxUsd   Float?
  quantity       Int       @default(1)
  deadlineMonths Int?
  description    String?
  status         String    @default("active")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  brand          Brand?    @relation(fields: [brandId], references: [id])
  buyer          User      @relation(fields: [buyerId], references: [id])
  category       Category? @relation(fields: [categoryId], references: [id])
}

model Inquiry {
  id        String   @id @default(cuid())
  productId String
  buyerId   String?
  name      String
  email     String?
  phone     String?
  company   String?
  message   String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  buyer     User?    @relation(fields: [buyerId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model InternationalPrice {
  id              String    @id @default(cuid())
  productId       String
  priceForeignCny Float
  priceForeignRaw Float?
  currency        String    @default("EUR")
  exchangeRate    Float?
  source          String
  sourceUrl       String?
  sourceDate      String?
  country         String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  confidenceScore Float     @default(0.5)
  isActive        Boolean   @default(true)
  lastVerified    DateTime?
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Valuation {
  id                String  @id @default(cuid())
  productId         String?
  brandId           String
  modelName         String
  year              Int
  workingHours      Int?
  estimatedPriceCny Float
  estimatedPriceUsd Float
  confidenceScore   Float   @default(0.5)
  factors           String?
  brand             Brand   @relation(fields: [brandId], references: [id])
}

model CreditTransaction {
  id         String    @id @default(cuid())
  userId     String
  type       String
  amount     Int
  balance    Int
  reason     String?
  relatedId  String?
  account    String?   // gift | recharge | mixed（扣减跨账户时）
  lotId      String?   // 入账时关联批次
  expiresAt  DateTime? // 入账时冗余批次过期时间
  breakdown  String?   // 扣减拆分 JSON：[{lotId, account, amount}]
  operatorId String?   // admin_adjust / 确认充值的操作人
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, type, createdAt])
}

model ExchangeRate {
  id             String   @id @default(cuid())
  baseCurrency   String   @default("CNY")
  targetCurrency String
  rate           Float
  source         String   @default("exchangerate-api")
  lastUpdated    DateTime @default(now())
  effectiveDate  DateTime

  @@unique([baseCurrency, targetCurrency, effectiveDate])
  @@index([baseCurrency, targetCurrency])
}

model ArbitrageTopCache {
  id               String   @id @default(cuid())
  productId        String
  rank             Int
  domesticPrice    Float
  foreignPrice     Float
  priceDiff        Float
  priceDiffPercent Float
  profitMargin     Float?
  lastCalculated   DateTime @default(now())
  validUntil       DateTime
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, rank])
  @@index([rank])
  @@index([validUntil])
}

model Article {
  id             String    @id @default(cuid())
  slug           String    @unique
  titleZh        String
  titleEn        String?
  titleRu        String?
  contentZh      String
  contentEn      String?
  contentRu      String?
  excerptZh      String?
  excerptEn      String?
  excerptRu      String?
  coverImage     String?
  status         String    @default("draft")
  category       String?
  tags           String?
  sourcePlatform String?
  sourceUrl      String?
  metaTitle      String?
  metaDesc       String?
  keywords       String?
  publishedAt    DateTime?
  viewCount      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  tagsEn         String?
  tagsRu         String?
  contentEs      String?
  contentPt      String?
  excerptEs      String?
  excerptPt      String?
  tagsEs         String?
  tagsPt         String?
  titleEs        String?
  titlePt        String?
  contentAr      String?
  contentFr      String?
  contentHi      String?
  excerptAr      String?
  excerptFr      String?
  excerptHi      String?
  tagsAr         String?
  tagsFr         String?
  tagsHi         String?
  titleAr        String?
  titleFr        String?
  titleHi        String?
  isPinned       Boolean   @default(false)

  @@index([status, publishedAt])
  @@index([category])
  @@index([sourcePlatform])
}

model MarketIntel {
  id                String   @id @default(cuid())
  date              DateTime
  icon              String
  region            String
  tags              String
  text              String
  url               String?
  detailedContent   String?
  dataSummary       String?
  actionTips        String?
  sortOrder         Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  detailedContentEn String?
  detailedContentRu String?
  regionEn          String?
  regionRu          String?
  tagsEn            String?
  tagsRu            String?
  textEn            String?
  textRu            String?
  detailedContentEs String?
  detailedContentPt String?
  regionEs          String?
  regionPt          String?
  tagsEs            String?
  tagsPt            String?
  textEs            String?
  textPt            String?
  detailedContentAr String?
  detailedContentFr String?
  detailedContentHi String?
  regionAr          String?
  regionFr          String?
  regionHi          String?
  tagsAr            String?
  tagsFr            String?
  tagsHi            String?
  textAr            String?
  textFr            String?
  textHi            String?

  @@index([date])
  @@index([isActive, date])
}

model ChatSession {
  id        String        @id @default(cuid())
  visitorId String
  productId String?
  locale    String        @default("en")
  status    String        @default("active")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@index([visitorId, status])
  @@index([productId])
  @@index([updatedAt])
}

model RawListing {
  id             String    @id @default(cuid())
  source         String
  sourceUrl      String
  status         String    @default("pending")
  brandName      String
  modelName      String
  year           Int?
  workingHours   Int?
  condition      String?
  priceRaw       Float?
  currency       String?
  priceCny       Float?
  location       String
  sellerName     String?
  sellerPhone    String?
  sellerWechat   String?
  sellerWhatsapp String?
  images         String?
  contentHash    String    @unique
  scrapedAt      DateTime  @default(now())
  reviewedAt     DateTime?
  reviewedBy     String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, scrapedAt])
  @@index([source, scrapedAt])
  @@index([contentHash])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String
  content   String
  intent    String?
  metadata  String?
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model AgentDefinition {
  id           String        @id @default(cuid())
  agentId      String        @unique
  name         String
  description  String?
  version      String        @default("0.1.0")
  triggerType  String        @default("manual")
  schedule     String?
  endpoint     String?
  dependencies String?
  status       String        @default("active")
  lastRunAt    DateTime?
  nextRunAt    DateTime?
  config       String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  runs         AgentRunLog[]

  @@index([status, agentId])
}

model AgentRunLog {
  id           String          @id @default(cuid())
  agentId      String
  triggeredBy  String          @default("manual")
  status       String
  startedAt    DateTime        @default(now())
  completedAt  DateTime?
  durationMs   Int?
  result       String?
  errorMessage String?
  metadata     String?
  createdAt    DateTime        @default(now())
  agent        AgentDefinition @relation(fields: [agentId], references: [agentId], onDelete: Cascade)

  @@index([agentId, startedAt])
  @@index([status, startedAt])
}

model MachineryIdentity {
  id              String           @id @default(cuid())
  productId       String           @unique
  qrCode          String           @unique
  serialNo        String?
  manufactureDate String?
  factoryName     String?
  factoryLocation String?
  verifyHash      String?
  isVerified      Boolean          @default(false)
  verifiedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  events          MachineryEvent[]
  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([qrCode])
}

model MachineryEvent {
  id          String            @id @default(cuid())
  identityId  String
  eventType   String
  title       String
  description String?
  operator    String?
  location    String?
  evidence    String?
  metadata    String?
  eventDate   DateTime          @default(now())
  createdAt   DateTime          @default(now())
  identity    MachineryIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@index([identityId, eventDate])
  @@index([eventType])
}

model Certification {
  id                  String    @id @default(cuid())
  userId              String
  certType            String
  status              String    @default("pending")
  applicantName       String
  contactPhone        String
  contactEmail        String?
  businessLicenseNo   String?
  businessLicenseImg  String?
  legalPerson         String?
  registeredCapital   String?
  businessScope       String?
  personnelName       String?
  personnelCertNo     String?
  personnelCertImg    String?
  personnelLevel      String?
  productId           String?
  inspectionReportNo  String?
  inspectionReportImg String?
  inspectionGrade     String?
  inspectionDate      DateTime?
  inspectionOrg       String?
  reviewedBy          String?
  reviewedAt          DateTime?
  reviewNote          String?
  validUntil          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, certType])
  @@index([status])
  @@index([certType, status])
}

model ServiceCenter {
  id                 String              @id @default(cuid())
  name               String
  level              String              @default("county")
  province           String
  city               String?
  district           String?
  address            String
  longitude          Float?
  latitude           Float?
  contactPerson      String?
  contactPhone       String?
  services           String?
  businessHours      String?
  images             String?
  description        String?
  isActive           Boolean             @default(true)
  sortOrder          Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  maintenanceRecords MaintenanceRecord[]

  @@index([province, level])
  @@index([isActive])
  @@index([level, isActive])
}

model InspectionReport {
  id              String    @id @default(cuid())
  productId       String
  inspectorId     String?
  inspectorName   String
  inspectionOrg   String?
  inspectionDate  DateTime  @default(now())
  overallGrade    String
  overallScore    Int
  inspectionItems String
  summary         String?
  recommendations String?
  photos          String?
  reportPdfUrl    String?
  status          String    @default("published")
  validUntil      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  inspector       User?     @relation(fields: [inspectorId], references: [id])
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([overallGrade])
  @@index([status, inspectionDate])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId, createdAt])
}

model Follow {
  id                  String   @id @default(cuid())
  userId              String
  sellerId            String
  createdAt           DateTime @default(now())
  notificationEnabled Boolean  @default(true)
  seller              User     @relation("FollowSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  user                User     @relation("FollowFollower", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sellerId])
  @@index([userId, createdAt])
  @@index([sellerId])
  @@index([notificationEnabled])
}

model SavedSearch {
  id             String    @id @default(cuid())
  userId         String
  name           String
  filters        String
  notifyOnNew    Boolean   @default(false)
  lastNotifiedAt DateTime?
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model SellerRating {
  id             String   @id @default(cuid())
  sellerId       String
  raterId        String
  productId      String?
  score          Int
  comment        String?
  itemMatchScore Int?
  serviceScore   Int?
  logisticsScore Int?
  createdAt      DateTime @default(now())
  rater          User     @relation("SellerRatingsGiven", fields: [raterId], references: [id], onDelete: Cascade)
  seller         User     @relation("SellerRatingsReceived", fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([sellerId, raterId, productId])
  @@index([sellerId, createdAt])
  @@index([raterId])
}

model PriceIndex {
  id             String   @id @default(cuid())
  date           DateTime
  category       String?
  brand          String?
  region         String?
  indexValue     Float
  avgPriceCny    Float
  sampleCount    Int
  monthOverMonth Float?
  yearOverYear   Float?
  metadata       String?
  createdAt      DateTime @default(now())

  @@unique([date, category, brand, region])
  @@index([date])
  @@index([category, date])
  @@index([brand, date])
}

model IndustryReport {
  id            String    @id @default(cuid())
  title         String
  reportType    String
  period        String
  summary       String
  content       String
  coverImage    String?
  keyMetrics    String?
  topBrands     String?
  topCategories String?
  priceTrends   String?
  status        String    @default("draft")
  publishedAt   DateTime?
  viewCount     Int       @default(0)
  downloadCount Int       @default(0)
  authorId      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, publishedAt])
  @@index([reportType, period])
}

model ElectronicContract {
  id              String     @id @default(cuid())
  contractNo      String     @unique
  productId       String
  sellerId        String
  buyerId         String
  title           String
  contractType    String     @default("sale")
  tradeTerm       String     @default("FOB")
  productInfo     String
  priceCny        Float
  priceUsd        Float?
  currency        String     @default("CNY")
  paymentMethod   String?
  deliveryDate    DateTime?
  deliveryAddress String?
  terms           String
  attachments     String?
  status          String     @default("draft")
  sellerSignedAt  DateTime?
  buyerSignedAt   DateTime?
  sellerSignature String?
  buyerSignature  String?
  pdfUrl          String?
  validFrom       DateTime?
  validUntil      DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
