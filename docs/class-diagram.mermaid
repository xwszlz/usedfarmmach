    SpecificationTableProps --> SpecificationTable : 渲染规格表
    SellerAiAssistantProps --> SellerAiAssistant : 渲染AI助手
    ProductUpdateBody --> "PUT /api/seller/products/[id]" : 请求体
    ProductEditData --> "edit/page.tsx" : 页面初始化
