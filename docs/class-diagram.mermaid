classDiagram
    class MachineType {
        +String id
        +String code
        +String nameZh
        +String nameEn
        +String nameRu
        +String nameEs
        +String namePt
        +String nameAr
        +String nameFr
        +String nameHi
        +String imageUrl
        +Int sortOrder
        +Boolean isActive
        +DateTime createdAt
        +DateTime updatedAt
    }

